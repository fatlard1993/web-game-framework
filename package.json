{
	"name": "@fatlard1993/web-game-framework",
	"version": "0.1.0-alpha.1",
	"type": "module",
	"description": "Lightweight framework for building multiplayer web games with Bun and WebSockets",
	"license": "MIT",
	"author": "fatlard1993",
	"repository": {
		"type": "git",
		"url": "https://github.com/fatlard1993/web-game-framework"
	},
	"exports": {
		".": "./index.js",
		"./core": "./core/index.js",
		"./core/Server": "./core/Server.js",
		"./core/Game": "./core/Game.js",
		"./core/Database": "./core/Database.js",
		"./core/Players": "./core/Players.js",
		"./client": "./client/index.js",
		"./client/socket": "./client/socket.js",
		"./client/gameContext": "./client/gameContext.js",
		"./plugins/*": "./plugins/*.js",
		"./ui": "./ui/index.js",
		"./ui/GameRoom": "./ui/GameRoom/index.js",
		"./ui/layout": "./ui/layout/index.js",
		"./ui/*": "./ui/*.js",
		"./utils": "./utils/index.js",
		"./utils/*": "./utils/*.js"
	},
	"files": [
		"core",
		"client",
		"plugins",
		"ui",
		"utils",
		"index.js",
		"README.md"
	],
	"keywords": [
		"game",
		"multiplayer",
		"websocket",
		"bun",
		"framework",
		"realtime"
	],
	"engines": {
		"bun": ">=1.0.0"
	},
	"browserslist": [
		"last 2 Chrome versions",
		"last 2 Firefox versions",
		"last 2 Safari versions",
		"last 2 Edge versions"
	],
	"scripts": {
		"prepare": "bun run prepare:githooks",
		"prepare:githooks": "[ -n \"$CI\" ] && exit 0 || (git config --local core.hooksPath .githooks || echo 'Can not set git hooks')",
		"lint": "bun --bun eslint",
		"lint:fix": "bun --bun eslint --fix",
		"format": "bun run lint:fix && bun --bun prettier --write . | grep -q unchanged",
		"test": "bun test",
		"test:watch": "bun test --watch"
	},
	"dependencies": {
		"lowdb": "^7.0.1",
		"nanoid": "^6.0.0",
		"@vanilla-bean/components": "^2.0.1",
		"@vanilla-bean/hypertether": "^1.0.1"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^9.39.5",
		"@happy-dom/global-registrator": "^18.0.1",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/user-event": "^14.6.1",
		"@types/bun": "^1.3.14",
		"bun-types": "^1.3.14",
		"eslint": "^10.7.0",
		"eslint-plugin-compat": "^7.0.2",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-jsdoc": "^54.7.0",
		"eslint-plugin-spellcheck": "0.0.20",
		"eslint-plugin-testing-library": "^7.16.2",
		"eslint-plugin-unicorn": "^64.0.0",
		"eslint-plugin-write-good-comments": "^0.2.0",
		"globals": "^16.5.0",
		"prettier": "^3.9.5"
	}
}
